# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Next Auth
# Generate: npx auth secret
AUTH_SECRET=""

# Prisma / PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/video-platform"

# ─── Pusher (Real-time messaging) ────────────────────────────────────────────
# Free account at https://pusher.com → Create App → Copy credentials
PUSHER_APP_ID=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"

# ─── Vercel Blob Storage ──────────────────────────────────────────────────────
# Get from Vercel Dashboard → Storage → Blob → Create Store → .env.local
BLOB_READ_WRITE_TOKEN=""

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Facebook OAuth (optional) ────────────────────────────────────────────────
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
